{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "env": {
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
        "ANTHROPIC_BASE_URL": "https://api2.ai.dev.nhk.jp",
        "ANTHROPIC_MODEL": "claude-opus-4-6-adaptive-thinking",
        "SEARCH_MODEL": "gemini-3-flash-preview"
    },
    "apiKeyHelper": "~/.claude/api-key-helper.sh",
    "teammateMode": "auto",
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "WebSearch",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/hooks/override_websearch.sh",
                        "timeout": 20
                    }
                ]
            }
        ]
    },
    "permissions": {
        "allow": [
            "Read(**)",
            "Edit(**)",
            "Glob(**)",
            "Grep(**)",
            "LS(**)",
            "WebSearch",
            "Bash(npm *)",
            "Bash(pnpm *)",
            "Bash(yarn *)",
            "Bash(node *)",
            "Bash(bun *)",
            "Bash(git *)",
            "Bash(tsc *)",
            "Bash(vite *)",
            "Bash(next *)",
            "Bash(eslint *)",
            "Bash(prettier *)",
            "Bash(tailwind *)"
        ],
        "deny": [
            "Read(**/.env*)",
            "Read(**/.env.**)",
            "Read(**/secrets/**)",
            "Read(**/*.key)",
            "Read(**/*.pem)",
            "Read(**/*.crt)",
            "Bash(rm -rf *)",
            "Bash(rm -r *)",
            "Bash(sudo *)",
            "Bash(chmod 777 *)",
            "Bash(curl *)",
            "Bash(wget *)",
            "Bash(ssh *)"
        ],
        "defaultMode": "acceptEdits"
    }
}